<?xml version="1.0" encoding="UTF-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  TasadorIA — Plantilla de importación Houzez / WordPress XML    ║
  ║  Instrucciones:                                                  ║
  ║  1. Duplicá cada bloque <item>...</item> para agregar propiedades║
  ║  2. Completá los campos marcados con ← EDITAR                   ║
  ║  3. Guardá como .xml y subí desde Admin → Importar XML          ║
  ║  Campos obligatorios: title, link, fave_property_price,         ║
  ║    fave_property_size, fave_property_country=Argentina          ║
  ╚══════════════════════════════════════════════════════════════════╝
-->
<rss version="2.0"
  xmlns:excerpt="http://wordpress.org/export/1.2/excerpt/"
  xmlns:content="http://purl.org/rss/1.0/modules/content/"
  xmlns:wfw="http://wellformedweb.org/CommentAPI/"
  xmlns:dc="http://purl.org/dc/elements/1.1/"
  xmlns:wp="http://wordpress.org/export/1.2/">

<channel>
  <title>TasadorIA Export</title>
  <link>https://tudominio.com</link>
  <wp:wxr_version>1.2</wp:wxr_version>

  <!-- ═══════════════════════════════════════════════════════
       PROPIEDAD 1 — Departamento en venta
       ═══════════════════════════════════════════════════ -->
  <item>
    <title>Departamento 3 ambientes Candioti Norte</title>             <!-- ← EDITAR: título de la propiedad -->
    <link>https://tudominio.com/propiedad/depto-candioti-norte</link> <!-- ← EDITAR: URL de la propiedad -->
    <pubDate>Mon, 13 Jan 2025 10:00:00 +0000</pubDate>               <!-- ← EDITAR: fecha de publicación -->

    <!-- Taxonomías: ciudad, tipo y operación -->
    <category domain="property_city"   nicename="candioti-norte"><![CDATA[Candioti Norte]]></category>  <!-- ← EDITAR: barrio/zona -->
    <category domain="property_type"   nicename="departamento"><![CDATA[departamento]]></category>      <!-- ← EDITAR: departamento | casa | ph | local | oficina | terreno -->
    <category domain="property_status" nicename="venta"><![CDATA[venta]]></category>                    <!-- ← EDITAR: venta | alquiler -->

    <wp:post_type>property</wp:post_type>   <!-- NO CAMBIAR -->
    <wp:status>publish</wp:status>           <!-- NO CAMBIAR -->
    <wp:post_id>1001</wp:post_id>           <!-- ← EDITAR: ID único por propiedad -->

    <!-- Metadatos de la propiedad -->
    <wp:postmeta><wp:meta_key>fave_property_country</wp:meta_key><wp:meta_value><![CDATA[Argentina]]></wp:meta_value></wp:postmeta>
    <wp:postmeta><wp:meta_key>fave_property_price</wp:meta_key><wp:meta_value><![CDATA[75000]]></wp:meta_value></wp:postmeta>          <!-- ← EDITAR: precio en USD (o ARS si moneda=ARS) -->
    <wp:postmeta><wp:meta_key>fave_currency</wp:meta_key><wp:meta_value><![CDATA[USD]]></wp:meta_value></wp:postmeta>                   <!-- ← EDITAR: USD | ARS -->
    <wp:postmeta><wp:meta_key>fave_property_size</wp:meta_key><wp:meta_value><![CDATA[72]]></wp:meta_value></wp:postmeta>               <!-- ← EDITAR: superficie cubierta en m² -->
    <wp:postmeta><wp:meta_key>fave_property_size_prefix</wp:meta_key><wp:meta_value><![CDATA[m2]]></wp:meta_value></wp:postmeta>        <!-- NO CAMBIAR -->
    <wp:postmeta><wp:meta_key>fave_property_land</wp:meta_key><wp:meta_value><![CDATA[80]]></wp:meta_value></wp:postmeta>               <!-- ← EDITAR: superficie total (puede ser igual a cubierta) -->
    <wp:postmeta><wp:meta_key>fave_property_bedrooms</wp:meta_key><wp:meta_value><![CDATA[2]]></wp:meta_value></wp:postmeta>            <!-- ← EDITAR: dormitorios -->
    <wp:postmeta><wp:meta_key>fave_property_bathrooms</wp:meta_key><wp:meta_value><![CDATA[1]]></wp:meta_value></wp:postmeta>           <!-- ← EDITAR: baños -->
    <wp:postmeta><wp:meta_key>fave_property_garage</wp:meta_key><wp:meta_value><![CDATA[1]]></wp:meta_value></wp:postmeta>              <!-- ← EDITAR: cocheras (0 si no tiene) -->
    <wp:postmeta><wp:meta_key>fave_property_map_address</wp:meta_key><wp:meta_value><![CDATA[Candioti Norte, Santa Fe, Argentina]]></wp:meta_value></wp:postmeta> <!-- ← EDITAR: dirección -->
    <wp:postmeta><wp:meta_key>houzez_geolocation_lat</wp:meta_key><wp:meta_value><![CDATA[-31.6200]]></wp:meta_value></wp:postmeta>     <!-- ← EDITAR: latitud (opcional) -->
    <wp:postmeta><wp:meta_key>houzez_geolocation_long</wp:meta_key><wp:meta_value><![CDATA[-60.6950]]></wp:meta_value></wp:postmeta>    <!-- ← EDITAR: longitud (opcional) -->
  </item>

